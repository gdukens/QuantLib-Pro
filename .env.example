# ─── ENVIRONMENT TEMPLATE ────────────────────────────────────────────────────
# Copy this file to .env and fill in values. NEVER commit .env to git.

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development       # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ─── Database (PostgreSQL - for audit log & user data) ───────────────────────
DATABASE_URL=postgresql://quantlib:REPLACE_WITH_DB_PASSWORD@localhost:5432/quantlib_pro
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── AWS Secrets Manager (production only) ───────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET

# ─── Streamlit ───────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ─── Observability ───────────────────────────────────────────────────────────
JAEGER_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
OTEL_SERVICE_NAME=quantlib-pro

# ─── Data Sources ────────────────────────────────────────────────────────────
# Optional: premium API key for alternative data provider
ALPHA_VANTAGE_API_KEY=REPLACE_IF_USING_ALPHA_VANTAGE
YFINANCE_MAX_RETRIES=3
YFINANCE_TIMEOUT_SECONDS=30

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_AUTH=false              # Set to true before any production deployment
ENABLE_RATE_LIMITING=false
ENABLE_AUDIT_LOG=true
ENABLE_GDPR_COMPLIANCE=false   # Set to true before launch
ENABLE_OBSERVABILITY=false     # Set to true in staging/production
